    <string name="home_title">EidKit</string>
    <string name="home_subtitle">The first Romanian app for reading, signing and authentication with the electronic identity card.</string>
    <string name="home_feature_kyc_title">KYC Read</string>
    <string name="home_feature_kyc_description">Read identity, photo, and verify document authenticity.</string>
    <string name="home_feature_auth_title">Authentication</string>
    <string name="home_feature_auth_description">Passwordless login — verify chip genuineness with active authentication.</string>
    <string name="home_feature_signing_title">Document Signing</string>
    <string name="home_feature_signing_description">Pick a PDF, sign it with the card\'s nonRepudiation key, and save the signed document.</string>
